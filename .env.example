# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agent_db"

# ── OpenAI / 9router ──────────────────────────────────────────────────────────
OPENAI_API_KEY="sua-chave-9router-aqui"
OPENAI_BASE_URL="http://localhost:20128"
MODEL_NAME="gpt-4.5"

# ── Negócio (preenchido automaticamente após POST /business) ──────────────────
BUSINESS_ID=""

# ── Porta do servidor ─────────────────────────────────────────────────────────
PORT=3000
APP_URL="http://localhost:3000"

# ── Google Calendar (opcional) ────────────────────────────────────────────────
GOOGLE_CALENDAR_ID=""
GOOGLE_SERVICE_ACCOUNT_JSON=''

# ── MercadoPago (opcional) ────────────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/pt/docs/credentials
MERCADOPAGO_ACCESS_TOKEN=""
# URL pública onde o MP enviará notificações de pagamento (use ngrok para testes locais)
MP_WEBHOOK_URL="https://SEU_DOMINIO/payment/webhook"
MP_STATEMENT_NAME="Salgaderia"

# ── Impressora Térmica (opcional) ─────────────────────────────────────────────
PRINTER_ENABLED=false
# Tipo: network | bluetooth | usb
PRINTER_TYPE=network
# Rede:      PRINTER_ADDRESS=192.168.1.100  PRINTER_PORT=9100
# Bluetooth: PRINTER_ADDRESS=/dev/rfcomm0  (Linux após parear: sudo rfcomm connect 0 AA:BB:CC:DD:EE:FF)
# Windows/WSL Bluetooth: PRINTER_ADDRESS=/dev/ttyS3  (veja COM port no Gerenciador de Dispositivos)
PRINTER_ADDRESS=192.168.1.100
PRINTER_PORT=9100
